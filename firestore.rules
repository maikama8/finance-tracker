rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if incoming data has userId matching auth
    function incomingDataHasValidUserId() {
      return request.resource.data.userId == request.auth.uid;
    }
    
    // Users collection - users can only access their own profile
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && incomingDataHasValidUserId();
      allow update: if isOwner(userId) && resource.data.userId == request.resource.data.userId;
      allow delete: if isOwner(userId);
    }
    
    // Transactions collection - users can only access their own transactions
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && incomingDataHasValidUserId();
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      resource.data.userId == request.resource.data.userId;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Categories collection - users can read all, but only modify their own custom categories
    // Default categories (userId == null) are read-only for all users
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                      (request.resource.data.userId == request.auth.uid || 
                       request.resource.data.userId == null);
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      resource.data.userId == request.resource.data.userId;
      allow delete: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid;
    }
    
    // Savings Goals collection - users can only access their own goals
    match /savings_goals/{goalId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && incomingDataHasValidUserId();
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      resource.data.userId == request.resource.data.userId;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Budgets collection - users can only access their own budgets
    match /budgets/{budgetId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && incomingDataHasValidUserId();
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      resource.data.userId == request.resource.data.userId;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // Exchange Rates collection - read-only for all authenticated users
    // Only backend services should write to this collection
    match /exchange_rates/{rateId} {
      allow read: if isAuthenticated();
      allow write: if false; // Only backend/admin can write
    }
    
    // Deny all other collections by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
